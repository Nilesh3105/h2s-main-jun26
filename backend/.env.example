# Sukoon backend configuration.
# Copy to `.env`. EVERY value here has a safe default — the app is fully
# functional with this file absent. Never commit a real .env (see .gitignore).

# --- Storage ---------------------------------------------------------------
# SQLite by default: zero-config and reproducible in a clean environment.
# DATABASE_URL=sqlite:///./sukoon.db

# --- CORS ------------------------------------------------------------------
# Comma-separated allowlist. Defaults to the local Vite dev server.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- GenAI (optional, additive) --------------------------------------------
# With NO key the app uses deterministic fallbacks for every AI surface and all
# tests still pass. Provide a Google AI Studio key to enable the GenAI voice.
# GOOGLE_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-3.5-flash
